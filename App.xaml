<Application x:Class="Castor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Castor"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                
                <!-- Сюда подключаем внешний файл стилей -->
                <ResourceDictionary Source="/assets/CastorGreen.xaml"/>
                <ResourceDictionary Source="/assets/Castor.xaml"/>
                <!-- Если есть другие словари — тоже сюда -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
