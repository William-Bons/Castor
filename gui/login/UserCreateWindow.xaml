<Window x:Class="Castor.gui.login.UserCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление пользователя" Height="488" Width="532"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Добавление нового пользователя"
                   Style="{StaticResource BaseText}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="ФИО" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="2"
                 x:Name="FullNameTextBox"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="Логин" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="4"
                 x:Name="LoginTextBox"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,12"/>

        <TextBlock Grid.Row="5" Text="Роль" Style="{StaticResource LabelText}" Margin="0,8,0,4"/>
        <ComboBox Grid.Row="6"
                  x:Name="RoleComboBox"
                  Style="{StaticResource ModernComboBox}"
                  Margin="0,0,0,12">
            <ComboBoxItem Content="Врач" IsSelected="True"/>
            <ComboBoxItem Content="Медсестра"/>
            <ComboBoxItem Content="Администратор"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Text="Пароль" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="8"
                     x:Name="PasswordBox"
                     Style="{StaticResource HardPasswordBox}"
                     Margin="0,0,0,8"/>

        <TextBlock Grid.Row="9" Text="Подтверждение пароля" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="10"
                     x:Name="ConfirmPasswordBox"
                     Style="{StaticResource HardPasswordBox}"
                     Margin="0,0,0,20"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right">
            
            <Button Content="Загрузить"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource HardButton}"
                    Click="Load_Click"/>
            
            <Button Content="Отмена"
                    Width="80"
                    Margin="0,0,10,0"
                    Style="{StaticResource HardButton}"
                    Click="Cancel_Click"/>

            <Button Content="Сохранить"
                    Width="100"
                    Style="{StaticResource AccentButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
