<Page x:Class="Castor.gui.pages.LoadPatientsFromMedis"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.dialogs"
        mc:Ignorable="d" d:Width="600" d:Height="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Фильтровать по выбранному врачу" Click="CurrentDocdepFilter">
                <Image Source="/img/filter.png" Width="32" Height="32"  />
            </Button>
        </ToolBar>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LoadedData.Visits, Mode=OneWay}" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="PatientSelectedToPlan" x:Name="PatientsTable" Language="RU">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Загружать" />
                <DataGridTextColumn Header="Отделение" Binding="{Binding Dep.text}"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding Patient.fullname}"/>
                <DataGridTextColumn Header="Врач" Binding="{Binding Doctor.text}" />
                <DataGridTextColumn Header="Возраст" Binding="{Binding Patient.age}" />
                <DataGridTextColumn Header="Дней" Binding="{Binding dat, StringFormat=\{0:d\}}" />
                <DataGridTextColumn Header="Дней" Binding="{Binding DaysInDep}" />
            </DataGrid.Columns>
        </DataGrid>
        
    </Grid>
</Page>
