<Page x:Class="Castor.gui.pages.Thebook"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Castor.gui.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Thebook">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Фильтровать" Click="NeedRefreshTable">
                <Image Source="/img/filter.png" Width="32" Height="32"  />
            </Button>
        </ToolBar>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LoadedData, Mode=OneWay}" AutoGenerateColumns="True" x:Name="PatientsTable" Language="RU" CellEditEnding="PatientsTable_CellEditEnding" >
            <!--<DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Загружать" />
                <DataGridTextColumn Header="№ карты" Binding="{Binding Card_id}"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding fio}"/>
                <DataGridTextColumn Header="Дата пост" Binding="{Binding datein}" />
                <DataGridTextColumn Header="Дата выб" Binding="{Binding dateout}" />
                <DataGridTextColumn Header="Дз пост" Binding="{Binding dsin}" />
                <DataGridTextColumn Header="Дз выб" Binding="{Binding dsout}" />
                <DataGridTextColumn Header="Первично" Binding="{Binding first}" />
                <DataGridTextColumn Header="Повт в году" Binding="{Binding second}" />
                <DataGridTextColumn Header="Возврат" Binding="{Binding early}" />
                <DataGridTextColumn Header="НГ" Binding="{Binding unvoluntary}" />
            </DataGrid.Columns>-->
        </DataGrid>

        <Button Grid.Row="1" Content="СОХРАНИТЬ" Height="20" Width="100" Margin="30" VerticalAlignment="Bottom" HorizontalAlignment="Right" Visibility="{Binding SaveButtonVisible}" Click="NeedRefreshTable"  />

    </Grid>

</Page>
