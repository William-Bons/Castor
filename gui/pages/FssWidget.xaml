<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Castor.gui.pages"
             xmlns:common="clr-namespace:Castor.gui.common" x:Class="Castor.gui.pages.FssWidget"
             mc:Ignorable="d" Language="RU"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <common:FssDateToColorConverter x:Key="FssDateToColorConverter"/>
        <common:FullnameConverter x:Key="FullnameConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontFamily="Courier New" FontSize="20" Margin="10"><Run Text="Сегодня ЭЛН" /></TextBlock>

        <DataGrid Grid.Row="1" HeadersVisibility="None" ItemsSource="{Binding FssList}" AutoGenerateColumns="False" FontFamily="Courier New" FontSize="20" BorderThickness="0" GridLinesVisibility="None" Margin="10" IsReadOnly="True" MouseDoubleClick="DataGrid_MouseDoubleClick" x:Name="FssGrid">
            <!--<DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>-->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!--подсветка зеленым история сдана-->
                        <DataTrigger Binding="{Binding FssControl.Nextvk, Converter={StaticResource FssDateToColorConverter}}" Value="1">
                            <Setter Property="Background" Value="#FFEAFFE2"/>
                        </DataTrigger>
                        <!-- Пример: Подсветка строки, если ошибка диагноза поступления -->
                        <DataTrigger Binding="{Binding FssControl.Nextvk, Converter={StaticResource FssDateToColorConverter}}" Value="2">
                            <Setter Property="Background" Value="#FFFFC8C8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Fio, Converter={StaticResource FullnameConverter}}" MaxWidth="200"/>
                <DataGridTextColumn Binding="{Binding FssControl.Nextvk}" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
