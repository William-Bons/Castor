<Window x:Class="Castor.gui.dialogs.SelectUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.dialogs"
        xmlns:common="clr-namespace:Castor.gui.common" 
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Выбор отделения"
        d:Width="500"
        d:Height="280"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResizeWithGrip"
        Background="#FAFBFC">

    <Window.Resources>
        <ResourceDictionary>
            <common:EnabledBoolConverter x:Key="EnabledBoolConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="Help" Executed="F1KeyPressed"/>
        <CommandBinding Command="Open" Executed="SelectDbDirectory"/>
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Command="Open" Gesture="F2"/>
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Иконка: компактно слева, не доминирует -->
        <Image Grid.Column="0"
               Source="/img/business_table_order_report_history_2332.ico"
               VerticalAlignment="Top"
               Margin="0,4,16,0"
               Width="36"
               Height="36"/>

        <!-- Основная панель формы -->
        <Border Grid.Column="1"
                Background="#FFFFFF"
                BorderBrush="{StaticResource Brush.Steel}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Отделение -->
                <TextBlock Grid.Row="0"
                   Text="Отделение"
                   Style="{StaticResource LabelText}"
                   Margin="0,0,0,6"/>

                <ComboBox Grid.Row="1"
          x:Name="comboBox"
          ItemsSource="{Binding Departments}"
          SelectedItem="{Binding SelectedDepartment}"
          SelectionChanged="DepartmentSelectedInCombo"
          Style="{StaticResource ModernComboBox}"
          MinWidth="300">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding text}"
                       VerticalAlignment="Center"
                       Padding="4,0"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Имя базы данных отделения -->
                <TextBlock Grid.Row="2"
                           Text="Имя базы данных отделения"
                           Style="{StaticResource LabelText}"
                           Margin="0,16,0,6"/>

                <!-- Строка: TextBox + кнопка выбора -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding DbFilename}"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1"
                            Content="..."
                            Style="{StaticResource HardButton}"
                            Padding="8,4"
                            Width="40"
                            Click="SelectDbDirectory"
                            Cursor="Hand"/>
                </Grid>

                <!-- Кнопки действий и подсказки -->
                <Grid Grid.Row="4" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Подсказка F1/F2 -->
                    <TextBlock Grid.Column="0"
                               Text="F1 — справка | F2 — выбрать папку"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <!-- Кнопка Сохранить -->
                    <Button Grid.Column="1"
                            Content="Сохранить"
                            Style="{StaticResource AccentButton}"
                            Click="SaveDialogButton"
                            IsDefault="True"
                            IsEnabled="{Binding SelectedItem, Converter={StaticResource EnabledBoolConverter}, ElementName=comboBox}"
                            Cursor="Hand"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
