<Window x:Class="Castor.gui.dialogs.UnvoluntaryControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.dialogs" xmlns:common="clr-namespace:Castor.gui.common"
        mc:Ignorable="d" Topmost="True" WindowStartupLocation="CenterScreen"
        FontFamily="Courier New" FontSize="15" Language="RU"
        Title="НГ" Height="237" Width="575">

    <Window.Resources>
        <common:DateOnlyConverter x:Key="DateOnlyConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="18*"/>
            <ColumnDefinition Width="95*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Margin="10,10,10,10" Grid.ColumnSpan="2" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Text="Дата поступления" Padding="2" />
            <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding UnlItem.Start, Converter={StaticResource DateOnlyConverter}}" Margin="2" />

            <TextBlock Grid.Row="1" Text="Дата снятия" Padding="2" />
            <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding UnlItem.End, Converter={StaticResource DateOnlyConverter}}" Margin="2" />
            <TextBlock Grid.Row="2" Text="Дата следующего ВК" Padding="2" />
            <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding UnlItem.Nextvk, Converter={StaticResource DateOnlyConverter}}" Margin="2" />

        </Grid>

        <StackPanel Grid.Column="2" Orientation="Vertical" Margin="10,10,10,10">
            <Button Content="Рассчитать" Click="Calculate" Margin="5" />
            <Button Content="Снять" Click="CloseEln" Margin="5" />
            <Separator/>
            <Button Content="Записать" Click="Write" Margin="5" />
        </StackPanel>

    </Grid>
</Window>
