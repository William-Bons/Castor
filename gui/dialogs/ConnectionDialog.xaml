<Window x:Class="Castor.gui.dialogs.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к PostgreSQL" 
        Width="460" Height="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource {x:Static SystemColors.WindowBrushKey}}" 
        Foreground="{StaticResource {x:Static SystemColors.WindowTextBrushKey}}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Хост -->
        <TextBlock Grid.Row="0" Text="Хост:" 
                   Style="{StaticResource LabelText}" 
                   VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="1" x:Name="HostBox" Text="localhost"
                 Style="{StaticResource ModernTextBox}"/>

        <!-- Порт -->
        <TextBlock Grid.Row="2" Text="Порт:" 
                   Style="{StaticResource LabelText}"
                   VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="3" x:Name="PortBox" Text="5432"
                 Style="{StaticResource ModernTextBox}"/>

        <!-- База данных -->
        <TextBlock Grid.Row="4" Text="База данных:" 
                   Style="{StaticResource LabelText}"
                   VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="5" x:Name="DatabaseBox"
                 Style="{StaticResource ModernTextBox}"/>

        <!-- Логин -->
        <TextBlock Grid.Row="6" Text="Логин:" 
                   Style="{StaticResource LabelText}"
                   VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="7" x:Name="UserBox"
                 Style="{StaticResource ModernTextBox}"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="8" Text="Пароль:" 
                   Style="{StaticResource LabelText}"
                   VerticalAlignment="Bottom"/>
        <!-- Используем твой стиль HardPasswordBox -->
        <PasswordBox Grid.Row="9" x:Name="PasswordBox"
                     Style="{StaticResource HardPasswordBox}"/>

        <!-- Статусная строка: мягкий фон, границы в стиле Steel -->
        <Border Grid.Row="10" 
                Background="#F9FAFC" 
                BorderBrush="{StaticResource Brush.Steel}" 
                BorderThickness="1" 
                CornerRadius="4"
                Padding="12"
                Margin="0,16,0,0">
            <TextBlock x:Name="StatusLabel" 
                       Text="Ожидание ввода..." 
                       Foreground="{StaticResource Brush.TextMain}" 
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки: используем AccentButton для ОК, HardButton для вторичных действий -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Проверить" 
                    Click="TestButton_Click" 
                    Width="90" Margin="0,0,12,0"
                    Style="{StaticResource HardButton}"/>

            <Button Content="ОК" IsDefault="True" 
                    Click="OkButton_Click" 
                    Width="80" Margin="0,0,12,0"
                    Style="{StaticResource AccentButton}"/>

            <Button Content="Отмена" IsCancel="True" 
                    Click="CancelButton_Click" 
                    Width="80"
                    Style="{StaticResource HardButton}"/>
        </StackPanel>
    </Grid>
</Window>
