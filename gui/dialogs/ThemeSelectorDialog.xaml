<Window x:Class="Castor.gui.dialogs.ThemeSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Выбор темы"
        Height="180"
        Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Graphite}">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Выберите тему оформления:"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource Brush.Accent}"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20">
                <Button x:Name="CastorSoftButton"
                       Content="CastorSoft (Синяя)"
                       Width="140"
                       Height="40"
                       Margin="0,0,10,0"
                       Click="CastorSoftButton_Click"
                       Style="{StaticResource AccentButton}"/>

                <Button x:Name="CastorGreenButton"
                       Content="CastorGreen (Зелёная)"
                       Width="140"
                       Height="40"
                       Click="CastorGreenButton_Click"
                       Style="{StaticResource AccentButton}"/>
            </StackPanel>

            <TextBlock x:Name="CurrentThemeLabel"
                      Text="Текущая тема: CastorSoft"
                      FontSize="11"
                      Foreground="{StaticResource Brush.TextSecondary}"
                      TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
