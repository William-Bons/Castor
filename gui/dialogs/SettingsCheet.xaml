<Window x:Class="Castor.gui.dialogs.SettingsCheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Параметры" Height="450" Width="800">

    <Window.CommandBindings>
        <CommandBinding Command="Save" Executed="Save"/>
    </Window.CommandBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="datas" Grid.Row="1" Grid.Column="0" ItemsSource="{Binding DataRows}" CanUserAddRows="False" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Header="Параметр" MaxWidth="250" />
                <DataGridTextColumn Binding="{Binding Type}" Header="Тип" MaxWidth="110"/>
                <DataGridTextColumn Binding="{Binding Value}" Header="Значение" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Vertical" Grid.Column="1" Grid.RowSpan="3" Margin="10">
            <Button Command="Save" Content="Записать" Padding="5"  />
        </StackPanel>

    </Grid>
</Window>
