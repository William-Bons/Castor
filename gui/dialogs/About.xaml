<Window x:Class="Castor.gui.dialogs.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.dialogs"
        mc:Ignorable="d" Topmost="True" WindowStartupLocation="CenterScreen"
        Title="About" Height="300" Width="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Image Source="/img/kurwa.jpg" />
        <StackPanel Grid.Column="1" Orientation="Vertical">
            <TextBlock FontFamily="Franklin Gothic Book" FontSize="18" TextAlignment="Center" Margin="30" LineHeight="27">
                <Run Text="Книга движения пациентов отделения" Foreground="Red" FontFamily="Impact"/>
                <LineBreak/>
                <Run Text="с дополнительными функциями"/>
                <LineBreak/>
                <Run Text="Иcпользвание разрешено исключительно"/>
                <LineBreak/>
                <Run Text="Дружносельская ПБ в составе"/>
                <LineBreak/>
                <Run Text="6 женское отделение"/>
                <LineBreak/>
                <Run Text="9 мужское отделение"/>
            </TextBlock>
            <Button Margin="20" HorizontalAlignment="Center" VerticalAlignment="Bottom" Content="Мне все понятно!" FontSize="15" Click="Exit"/>
        </StackPanel>

    </Grid>
</Window>
