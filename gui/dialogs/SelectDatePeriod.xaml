<Window x:Class="Castor.gui.dialogs.SelectDatePeriod"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.dialogs"
        mc:Ignorable="d"
        Title="Выбор периода" 
        Width="380" Height="220" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Surface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
            <!-- Строка для кнопок -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дата начала -->
        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Text="Дата начала" 
                   VerticalAlignment="Center"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   FontWeight="SemiBold"
                   Margin="0,0,12,0"/>

        <DatePicker Grid.Row="0" Grid.Column="1" 
                    Margin="0,4,0,8"
                    SelectedDate="{Binding Period.Start, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource ModernDatePicker}"/>
        <!-- Если у тебя есть такой стиль -->
        <!-- Если стиля ModernDatePicker нет, WPF использует дефолтный, но цвета подхватятся из ресурсов, если они заданы в App.xaml -->

        <!-- Дата конца -->
        <TextBlock Grid.Row="1" Grid.Column="0" 
                   Text="Дата окончания" 
                   VerticalAlignment="Center"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   FontWeight="SemiBold"
                   Margin="0,0,12,0"/>

        <DatePicker Grid.Row="1" Grid.Column="1" 
                    Margin="0,4,0,8"
                    SelectedDate="{Binding Period.End, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource ModernDatePicker}"/>

        <!-- Панель кнопок (ОК / Отмена) -->
        <StackPanel Grid.Row="2" Grid.Column="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom">

            <!-- Кнопка Отмена (нейтральная) -->
            <Button Content="Отмена" 
                    Width="80" 
                    Margin="0,0,10,0"
                    Command="{Binding CancelCommand}" 
                    Style="{StaticResource HardButton}"/>

            <!-- Кнопка ОК (акцентная) -->
            <Button Content="ОК" 
                    Width="80" 
                    Command="{Binding OkCommand}"
                    Style="{StaticResource AccentButton}">
            </Button>
        </StackPanel>
    </Grid>
</Window>
