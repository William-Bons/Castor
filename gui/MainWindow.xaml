<Window x:Class="Castor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor"
        xmlns:gui="clr-namespace:Castor.gui" 
        xmlns:pages="clr-namespace:Castor.gui.pages"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="{Binding Depname}" Height="450" Width="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="Transparent" x:Name="CentralMenu"/>

        <Grid Grid.Row="2" x:Name="MainFrameGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Frame Grid.Column="1" x:Name="CentralFrame" Visibility="Visible" NavigationUIVisibility="Hidden"/>
            <!--<StackPanel Orientation="Vertical" Grid.Column="1" x:Name="CentralStack">
                <pages:Weekmove  />
                <Separator/>
                <pages:FssControl />
                <Separator/>
                <pages:ForceControl/>
            </StackPanel>-->
            
        </Grid>
        

        <!--<gui:CastorConsole Grid.Row="3" MinHeight="120" x:Name="Console" d:Visibility="Visible"/>-->
        <StatusBar Grid.Row="4" Padding="0" x:Name="MainStatusBar">
            <TextBlock Padding="0" x:Name="main" Text="{Binding CurrentDbName}"/>
            <TextBlock Name="status" Padding="0" Text="{Binding Depname}" />
            <TextBlock Padding="0" x:Name="ConsoleMessage" />
        </StatusBar>
    </Grid>
</Window>
