<Page x:Class="Castor.gui.movebook.ImportMedisPeriod"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Castor.gui.movebook"
      mc:Ignorable="d"
      Title="Импорт периодов MEDIS" 
      d:Height="520" 
      d:Width="900"
      Background="#FAFBFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Панель инструментов -->
            <RowDefinition Height="4"/>
            <!-- Отступ -->
            <RowDefinition/>
            <!-- Таблица -->
            <RowDefinition Height="Auto"/>
            <!-- Футер/статус -->
        </Grid.RowDefinitions>

        <!-- Панель действий вместо ToolBar -->
        <!-- Заголовок и кнопка добавления (мягкий вариант) -->
        <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="{StaticResource Brush.Steel}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,8"
            Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                   Text="{Binding Title}"
                   Foreground="{StaticResource Brush.TextMain}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>

                <Grid Grid.Column="1">
                    <!-- Основной ToggleButton -->
                    <ToggleButton x:Name="DropdownToggle"
                          Content="Действия ▼" IsChecked="{Binding IsMenuOpen}"
                          Style="{StaticResource ModernDropdownButton}"/>

                    <!-- Popup с меню -->
                    <Popup PlacementTarget="{Binding ElementName=DropdownToggle}"
                       IsOpen="{Binding IsChecked, ElementName=DropdownToggle, Mode=OneWay}"
                       AllowsTransparency="True"
                       StaysOpen="False"
                       Margin="0,28,0,0">
                        <!-- отступ сверху под кнопку -->

                        <Border Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="4">

                            <StackPanel Margin="8">

                                <MenuItem Header="Фильтр дат"
                                  Command="{Binding FilterCommand}" CommandParameter="P"
                                  Style="{StaticResource MenuItemStyle}"/>

                                <MenuItem Header="Записать выделенных"
                                  Command="{Binding SaveCommand}" 
                                  Style="{StaticResource MenuItemStyle}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>


            </Grid>
        </Border>

        <!-- DataGrid с явными колонками (пример структуры для мед. данных) -->
        <DataGrid Grid.Row="2" 
                  x:Name="MedisDataGrid" Style="{StaticResource MovebookDataGridStyle}"
                  ItemsSource="{Binding DataRowSource, Mode=OneWay}" 
                  SelectedItem="{Binding SelectedDataItem, UpdateSourceTrigger=PropertyChanged}"
                  Language="RU">

            <DataGrid.Columns>
                <!-- Пример колонок. Замени на реальные поля твоей модели DataRowSource -->
                <DataGridCheckBoxColumn Binding="{Binding IsSelected}" />
                <DataGridTextColumn Header="№ и/б" Binding="{Binding Movebook.Card_Id}" Width="100"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding Movebook.Fio}" />
                <DataGridTextColumn Header="Диагноз" Binding="{Binding Movebook.Dsin}" Width="120"/>
                <DataGridTextColumn Header="Дата пост" Binding="{Binding Movebook.Datein, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Дата выб" Binding="{Binding Movebook.Dateout, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Дней в стационаре" Binding="{Binding Movebook.Days}" Width="150"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- Опционально: строка статуса внизу -->
        <TextBlock Grid.Row="3" 
                   x:Name="StatusLabel"
                   Text="{Binding StatusMessage}" 
                   Foreground="{StaticResource Brush.TextSecondary}"
                   Margin="0,10,0,0"
                   VerticalAlignment="Bottom"/>
    </Grid>
</Page>
