<Window x:Class="Castor.gui.movebook.CreateNew"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.movebook"
        mc:Ignorable="d" 
        Title="Поступление" Height="534" Width="632" WindowStartupLocation="CenterScreen" Topmost="True"
        FontFamily="Courier New" FontSize="16">
    
    <Window.Resources>
        <local:DateOnlyConverter x:Key="DateOnlyConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock FontFamily="Arial" FontSize="25" Text="Проверьте правильность заполнения всех полей" Foreground="OrangeRed" TextAlignment="Center" Padding="5"/>
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Отделение" Padding="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Dep.text}" DataContext="{Binding Visit}" Padding="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Пациент" Padding="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1"  Padding="5">
                    <Run Text="{Binding Patient.fullname, Mode=OneWay}" DataContext="{Binding Visit}" />
                    <LineBreak/>
                    <Run Text="{Binding CurrentDs.text, Mode=OneWay}" DataContext="{Binding Visit.Patient}"/>
                </TextBlock>
                <Button    Grid.Row="1" Grid.Column="1" Content="..." Width="23" Height="23" HorizontalAlignment="Right" Click="SelectPatientFromMedis"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Поступил из" Padding="5"/>
                <ComboBox  Grid.Row="2" Grid.Column="1" Margin="3" SelectedValuePath="Tag" SelectedValue="{Binding Movebook.Ordered}">
                    <ComboBoxItem Tag="0">Дома</ComboBoxItem>
                    <ComboBoxItem Tag="1">Стацонара</ComboBoxItem>
                    <ComboBoxItem Tag="2">ПНИ</ComboBoxItem>
                </ComboBox>

                <TextBlock  Grid.Row="3" Grid.Column="0" Text="Дата поступления" Padding="5"/>
                <DatePicker Grid.Row="3" Grid.Column="1" Margin="3" SelectedDate="{Binding Movebook.Datein, Converter={StaticResource DateOnlyConverter}}" x:Name="DateInControl"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Диагноз поступления" Padding="5"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Movebook.Dsin}"  Margin="3" Padding="2"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Городской" Padding="5"/>
                <CheckBox  Grid.Row="5" Grid.Column="1" IsChecked="{Binding Movebook.City}" Margin="5" ToolTip="отметьте поле, если пациент прописан в городе, в ином случае оставте поле неотмеченым" FontSize="11"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Впервые в жизни" Padding="5"/>
                <CheckBox  Grid.Row="6" Grid.Column="1" IsChecked="{Binding Movebook.First}" Margin="5" ToolTip="отметьте поле, если пациент ранее никогда не лечился в любых психиатрических стационарах" FontSize="11"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Повторно в году" Padding="5"/>
                <CheckBox  Grid.Row="7" Grid.Column="1" IsChecked="{Binding Movebook.Second}" Margin="5" ToolTip="отметьте поле, если пациент поступает повторно в этом календарном году" FontSize="11"/>
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Недобровольно" Padding="5"/>
                <CheckBox  Grid.Row="8" Grid.Column="1" IsChecked="{Binding Movebook.Unvoluntary}" Margin="5" ToolTip="отметьте поле, если пациент поступил по ст 29" FontSize="11"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Ранний возврат" Padding="5" />
                <CheckBox  Grid.Row="9" Grid.Column="1" IsChecked="{Binding Movebook.Early}" Margin="5" ToolTip="отметьте поле, если пациент поступил менее чем через 2 недели после выписки" FontSize="11" />
                <TextBlock  Grid.Row="10" Grid.Column="0" Text="Дата пред выписки" Padding="5"/>
                <DatePicker Grid.Row="10" Grid.Column="1" Margin="3" SelectedDate="{Binding Movebook.Date_lastout, Converter={StaticResource DateOnlyConverter}}"/>
                <Rectangle Grid.Row="9" Grid.RowSpan="2" Grid.ColumnSpan="2" Stroke="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}" />


            </Grid>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Cancel" Width="100" Click="Cancel"/>
            <Separator Width="5" Visibility="Hidden"/>
            <Button Content="OK" Width="100" Click="SaveInDb"/>
        </StackPanel>

    </Grid>
</Window>
