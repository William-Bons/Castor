<UserControl x:Class="Castor.gui.movebook.SelectPatientInVisits"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Castor.gui.movebook"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DataGrid IsReadOnly="True" AutoGenerateColumns="False" ItemsSource="{Binding RowSourceObject}" Language="RU" MouseDoubleClick="DataGrid_MouseDoubleClick">
        <DataGrid.Columns>
            <DataGridTextColumn Header="No" Binding="{Binding Patient.num}"/>
            <DataGridTextColumn Header="No" Binding="{Binding num}"/>
            <DataGridTextColumn Header="Date" Binding="{Binding dat, StringFormat=d}"  />
            <DataGridTextColumn Header="Date" Binding="{Binding dat1, StringFormat=d}"  />
            <DataGridTextColumn Header="Name" Binding="{Binding Patient.lastname}"/>
            <DataGridTextColumn Header="Birth" Binding="{Binding Patient.birthdate, StringFormat=d}" />
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
