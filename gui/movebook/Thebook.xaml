<Page x:Class="Castor.gui.movebook.Thebook"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Castor.gui.pages"
      xmlns:common="clr-namespace:Castor.gui.common" 
      xmlns:local1="clr-namespace:Castor.gui.movebook" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1191.778"
      Background="#FAFBFC"
      x:Name="ThebookElement">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/assets/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local1:MovefilterHeaderItemConverter x:Key="MovefilterHeaderItemConverter"/>
            <common:EnabledBoolConverter x:Key="EnabledBoolConverter"/>
            <common:FssLogoConverter x:Key="FssLogoConverter"/>
            <common:ObjectToVisibleConverter x:Key="ObjectToVisibleConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель действий вместо ToolBar -->
        <!-- Заголовок и кнопка добавления (мягкий вариант) -->
        <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="{StaticResource Brush.Steel}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,8"
            Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                   Text="Список пациентов отделения"
                   Foreground="{StaticResource Brush.TextMain}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>

                <Grid Grid.Column="1">
                    <!-- Основной ToggleButton -->
                    <ToggleButton x:Name="DropdownToggle"
                          Content="Действия ▼" IsChecked="{Binding IsMenuOpen}"
                          Style="{StaticResource ModernDropdownButton}"/>

                    <!-- Popup с меню -->
                    <Popup PlacementTarget="{Binding ElementName=DropdownToggle}"
                       IsOpen="{Binding IsChecked, ElementName=DropdownToggle, Mode=OneWay}"
                       AllowsTransparency="True"
                       StaysOpen="False"
                       Margin="0,28,0,0">
                        <!-- отступ сверху под кнопку -->

                        <Border Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="4">

                            <StackPanel Margin="8">
                                <MenuItem Header="{Binding FilterPeriod.IsHideClosedCards, ConverterParameter=Скрыть сданные истории, Converter={StaticResource MovefilterHeaderItemConverter}}"
                                  Command="{Binding FilterCommand}" CommandParameter="C"
                                  Style="{StaticResource MenuItemStyle}"/>

                                <MenuItem Header="{Binding FilterPeriod.IsHideDisordered, ConverterParameter=Скрыть выписанные истории, Converter={StaticResource MovefilterHeaderItemConverter}}" 
                                  Command="{Binding FilterCommand}" CommandParameter="D"
                                  Style="{StaticResource  MenuItemStyle}"/>

                                <Separator Style="{StaticResource  SeparatorStyle}"/>

                                <MenuItem Header="Фильтр дат"
                                  Command="{Binding FilterCommand}" CommandParameter="P"
                                  Style="{StaticResource MenuItemStyle}"/>

                                <MenuItem Header="Выписать"
                                  Command="{Binding DisorderPatientCommand}" 
                                  Style="{StaticResource MenuItemStyle}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

            </Grid>
        </Border>


        <DataGrid Grid.Row="1" ItemsSource="{Binding LoadedData, Mode=OneWay}" AutoGenerateColumns="False" Language="RU" FontFamily="Courier New" FontSize="16" SelectionMode="Single" MouseDoubleClick="PatientsTable_MouseDoubleClick" CanUserAddRows="False" SelectedItem="{Binding Selected}" x:Name="MovebookDataGrid" >
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Редактировать запись" Command="{Binding EditCommand}" Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="Выписать" Command="{Binding DisorderPatientCommand}"  Style="{StaticResource MenuItemStyle}"/>
                    <MenuItem Header="Удалить запись" Command="{Binding DeleteCommand}" Style="{StaticResource MenuItemStyle}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.RowStyle>
                <Style TargetType="{x:Type DataGridRow}">
                    <Style.Triggers>
                        <!--подсветка зеленым история сдана-->
                        <DataTrigger Binding="{Binding Closed}" Value="True">
                            <Setter Property="Background" Value="#FFEAFFE2"/>
                        </DataTrigger>
                        <!-- Пример: Подсветка строки, если ошибка диагноза поступления -->
                        <DataTrigger Binding="{Binding InControl}" Value="False">
                            <Setter Property="Background" Value="#FFFFC8C8"/>
                        </DataTrigger>
                        <!-- Пример: Подсветка строки, если ошибка диагноза выбытия -->
                        <DataTrigger Binding="{Binding OutControl}" Value="False">
                            <Setter Property="Background" Value="#FFFFC8C8"/>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ПММХ">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DataGridNoHoverButton}" Click="OpenPMMCommand">
                                <Image Source="/img/jail-icon.png" Width="25" Height="25" Visibility="{Binding Forceds, Converter={StaticResource ObjectToVisibleConverter}}"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="ВК">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DataGridNoHoverButton}" Click="OpenCMCommand">
                                <Image Source="/img/fsslogo.png" Width="25" Height="25" Visibility="{Binding Commities, Converter={StaticResource ObjectToVisibleConverter}}"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn Header="№ карты" Binding="{Binding Card_Id}"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding Fio}"/>
                <DataGridTextColumn Header="Дата пост" Binding="{Binding Datein}" />
                <DataGridTextColumn Header="Дата выбытия" Binding="{Binding Dateout}" />
                <DataGridTextColumn Header="Дз пост" Binding="{Binding Dsin}" />
                <DataGridTextColumn Header="Дз выб" Binding="{Binding Dsout}" />
                <DataGridCheckBoxColumn Header="Первично" Binding="{Binding First}" />
                <DataGridCheckBoxColumn Header="Повт в году" Binding="{Binding Second}" />
                <DataGridCheckBoxColumn Header="Возврат" Binding="{Binding Early}" />
                <DataGridCheckBoxColumn Header="История сдана" Binding="{Binding Closed}" />
                <DataGridCheckBoxColumn Header="Скончался" Binding="{Binding Deceased}" />
                
                
            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</Page>
