<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Castor.gui.pages"
      xmlns:common="clr-namespace:Castor.gui.common" xmlns:local1="clr-namespace:Castor.gui.movebook" x:Class="Castor.gui.movebook.Thebook"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1191.778"
      x:Name="ThebookElement">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/assets/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <common:FssLogoConverter x:Key="FssLogoConverter"/>
            <common:ObjectToVisibleConverter x:Key="ObjectToVisibleConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Импортировать из Медис" Click="ImportList" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/log_logout_door_1563.ico" />
                    <TextBlock Text="Поступление" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Добавить пациента в книгу движения" Click="LoadPatient" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/add-icon.png" />
                    <TextBlock Text="Добавить" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Выписать пациента" Click="DisorderPatient" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/fire_exit_emergency_door_icon_196783.ico" />
                    <TextBlock Text="Выписать" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Отчет ДВИЖЕНИЕ" Click="SaveInXml"  Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/business_table_order_report_history_2332.ico" />
                    <TextBlock Text="Отчет Движение" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Фильтр"  Style="{DynamicResource Castor.Toolbarbutton}" Click="OpenHideContextMenu">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Скрыть сданные истории" IsCheckable="True" Click="HideShowClosedCards"  x:Name="Hideclosed"/>
                        <MenuItem Header="Скрыть выписанные истории" IsCheckable="True" Click="HideShowDisordered" x:Name="Hidedisordered"/>
                        <MenuItem Header="Фильтр дат" IsCheckable="True" Click="FilterByDatePeriod" />
                    </ContextMenu>
                </Button.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/filter.png" />
                    <TextBlock Text="Фильтр" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Visibility="{Binding SaveButtonVisible}" Click="NeedRefreshTable" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/floppy_mount.png"/>
                    <TextBlock Text="Сохранить" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </ToolBar>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LoadedData, Mode=OneWay}" AutoGenerateColumns="False" x:Name="PatientsTable" Language="RU" CellEditEnding="PatientsTable_CellEditEnding" CurrentCellChanged="PatientsTable_CellEditEnding" FontFamily="Courier New" FontSize="16" SelectionMode="Single" MouseDoubleClick="PatientsTable_MouseDoubleClick" CanUserAddRows="False">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Click="LoadPatient" Header="Редактировать" />
                    <MenuItem Click="DeleteRow" Header="Удалить запись"/>
                    <MenuItem Click="ShowStatGroup" Header="Показатели" />
                    <MenuItem Click="HideAutoColumns" Header="Показывать все колонки" IsCheckable="True"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.RowStyle>
                <Style TargetType="{x:Type DataGridRow}">
                    <Style.Triggers>
                        <!--подсветка зеленым история сдана-->
                        <DataTrigger Binding="{Binding Closed}" Value="True">
                            <Setter Property="Background" Value="#FFEAFFE2"/>
                        </DataTrigger>
                        <!-- Пример: Подсветка строки, если ошибка диагноза поступления -->
                        <DataTrigger Binding="{Binding InControl}" Value="False">
                            <Setter Property="Background" Value="#FFFFC8C8"/>
                        </DataTrigger>
                        <!-- Пример: Подсветка строки, если ошибка диагноза выбытия -->
                        <DataTrigger Binding="{Binding OutControl}" Value="False">
                            <Setter Property="Background" Value="#FFFFC8C8"/>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button BorderThickness="0" Margin="2" Click="DisorderPatient" Content="Выписать"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="№ карты" Binding="{Binding Card_Id}"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding Fio}"/>
                <DataGridTextColumn Header="Дата пост" Binding="{Binding Datein}" />
                <DataGridTextColumn Header="Дата выб" Binding="{Binding Dateout}" />
                <DataGridTextColumn Header="Дз пост" Binding="{Binding Dsin}" />
                <DataGridTextColumn Header="Дз выб" Binding="{Binding Dsout}" />
                <DataGridCheckBoxColumn Header="Первично" Binding="{Binding First}" />
                <DataGridCheckBoxColumn Header="Повт в году" Binding="{Binding Second}" />
                <DataGridCheckBoxColumn Header="Возврат" Binding="{Binding Early}" />
                <DataGridCheckBoxColumn Header="История сдана" Binding="{Binding Closed}" />
                <DataGridCheckBoxColumn Header="Скончался" Binding="{Binding Deceased}" />
                <DataGridTemplateColumn Header="НГ">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="/img/policeman-icon.png" Width="25" Height="25" Visibility="{Binding Unvoluntaryid, Converter={StaticResource ObjectToVisibleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="ЭЛН">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding FssControl, Converter={StaticResource FssLogoConverter}}" Width="25" Height="25" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="ПММХ">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="/img/jail-icon.png" Width="25" Height="25" Visibility="{Binding Forcedid, Converter={StaticResource ObjectToVisibleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>



    </Grid>

</Page>
