<Window x:Class="Castor.gui.movebook.DisplayReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Castor.gui.movebook"
        mc:Ignorable="d"
        Title="DisplayReport" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Фильтровать" Click="SaveToDisk"  Width="32" Height="32">
                <Image Source="/img/floppy_mount.png" />
            </Button>
            <Button ToolTip="Фильтровать" Command="Print"  Width="32" Height="32">
                <Image Source="/img/acroread.png" />
            </Button>
        </ToolBar>

        <WebBrowser Grid.Row="1" x:Name="Browser"/>

    </Grid>
</Window>
