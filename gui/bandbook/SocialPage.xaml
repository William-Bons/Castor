<UserControl x:Class="Castor.gui.bandbook.SocialPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Castor.gui.bandbook"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="1" Grid.Row="1" Text="Жилищные условия" Padding="3"/>
        <StackPanel Grid.Column="2" Grid.Row="1" Margin="3"  Orientation="Vertical">
            <ComboBox SelectedValue="{Binding Bandline.point04}">
                <ComboBoxItem>Удовлетворительные</ComboBoxItem>
                <ComboBoxItem>Неудовлетворительные</ComboBoxItem>
                <ComboBoxItem>Жилье утрачено</ComboBoxItem>
            </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        

        <TextBlock Grid.Column="1" Grid.Row="2" Text="Личные документы" Padding="3"/>
        <StackPanel Grid.Column="2" Grid.Row="2" Margin="3" Orientation="Vertical">
            <ComboBox SelectedValue="{Binding Bandline.point05}">
                <ComboBoxItem>В наличии все</ComboBoxItem>
                <ComboBoxItem>В наличии частично</ComboBoxItem>
                <ComboBoxItem>Утрачены</ComboBoxItem>
            </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        

        <TextBlock Grid.Column="1" Grid.Row="3" Text="Семейное положение" Padding="3"/>
        <StackPanel  Grid.Column="2" Grid.Row="3" Margin="3" Orientation="Vertical">
            <ComboBox SelectedValue="{Binding Bandline.point05}">
                <ComboBoxItem>В браке</ComboBoxItem>
                <ComboBoxItem>Одинок</ComboBoxItem>
                <ComboBoxItem>В семье</ComboBoxItem>
            </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        
        
        <TextBlock Grid.Column="1" Grid.Row="4" Text="Образование" Padding="3"/>
        <StackPanel Grid.Column="2" Grid.Row="4" Margin="3" Orientation="Vertical">
            <ComboBox  SelectedValue="{Binding Bandline.point05}">
            <ComboBoxItem>Высшее</ComboBoxItem>
            <ComboBoxItem>Среднее</ComboBoxItem>
            <ComboBoxItem>Начальное</ComboBoxItem>
            <ComboBoxItem>Не имеет</ComboBoxItem>
        </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        
        
        <TextBlock Grid.Column="1" Grid.Row="5" Text="Трудовая деятельность" Padding="3"/>
        <StackPanel  Grid.Column="2" Grid.Row="5" Margin="3" Orientation="Vertical">
            <ComboBox SelectedValue="{Binding Bandline.point05}">
            <ComboBoxItem>Работает</ComboBoxItem>
            <ComboBoxItem>Не работает, но имеет специальность</ComboBoxItem>
            <ComboBoxItem>Не имеет профессии</ComboBoxItem>
            <ComboBoxItem>Трудовые наавыки утрачены</ComboBoxItem>
        </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        
        
        <TextBlock Grid.Column="1" Grid.Row="7" Text="Инвалидность" Padding="3"/>
        <StackPanel Grid.Column="2" Grid.Row="7" Margin="3" Orientation="Vertical">
            <ComboBox  SelectedValue="{Binding Bandline.point05}">
                <ComboBoxItem>Не имеет признаков инвалидности</ComboBoxItem>
                <ComboBoxItem>Имеет признаки, но инвалидность не оформлена</ComboBoxItem>
                <ComboBoxItem>Инвалидизирован</ComboBoxItem>
                <ComboBoxItem>Все ужасно</ComboBoxItem>
            </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        
        
        <TextBlock Grid.Column="1" Grid.Row="8" Text="Источник содержания" Padding="3"/>
        <StackPanel  Grid.Column="2" Grid.Row="8" Margin="3" Orientation="Vertical">
            <ComboBox SelectedValue="{Binding Bandline.point05}">
                <ComboBoxItem>Содержит себя самостоятельно</ComboBoxItem>
                <ComboBoxItem>На иждивении</ComboBoxItem>
                <ComboBoxItem>Пенсия</ComboBoxItem>
                <ComboBoxItem>Не имеет источника средств</ComboBoxItem>
            </ComboBox>
            <TextBox Margin="3" TextWrapping="Wrap"  AcceptsReturn="True" />
        </StackPanel>
        
        
        <TextBlock Grid.Column="1" Grid.Row="9" Text="Дееспособность" Padding="3"/>
        <ComboBox  Grid.Column="2" Grid.Row="9" Margin="3" SelectedValue="{Binding Bandline.point05}">

        </ComboBox>
        
        <Separator Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"/>
        <TextBlock Grid.Column="1" Grid.Row="11" Text="Социальный диагноз" Padding="3"/>
        <ComboBox  Grid.Column="2" Grid.Row="12" Margin="3" SelectedValue="{Binding Bandline.point05}">

        </ComboBox>
        
        <TextBlock Grid.Column="1" Grid.Row="12" Text="" Padding="3"/>

        <TextBlock Grid.Column="1" Grid.Row="13" Text="" Padding="3"/>

        <TextBlock Grid.Column="1" Grid.Row="14" Text="" Padding="3"/>

    </Grid>
</UserControl>
