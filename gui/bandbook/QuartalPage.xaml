<UserControl x:Class="Castor.gui.bandbook.QuartalPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Castor.gui.bandbook"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <DataGrid AutoGenerateColumns="True" CanUserAddRows="False" x:Name="QuartalDataGrid" ItemsSource="{Binding QuartalData}" SelectionChanged="QuartalDataGrid_Selected"/>
</UserControl>
