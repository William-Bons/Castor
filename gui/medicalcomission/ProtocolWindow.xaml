<Window x:Class="Castor.gui.medicalcomission.ProtocolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Castor.gui.medicalcomission"
        Title="Протокол врачебной комиссии"
        Height="850" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:HasValueConverter x:Key="HasValueConverter"/>
        <!-- остальные ресурсы -->
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка: основные реквизиты -->
        <Border Grid.Row="0" Style="{StaticResource ModernBorder}" Margin="0,0,0,20" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="№ протокола" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ProtocolNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Дата" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,6"/>
                    <DatePicker SelectedDate="{Binding ProtocolDate}"
                                Background="#FFFFFF" BorderBrush="{StaticResource Brush.Steel}"
                                Padding="8" Height="36" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Время" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ProtocolTime, StringFormat=t, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Height="36"
                             ToolTip="Формат: ЧЧ:ММ (например, 14:30)"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource ModernBorder}" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Место и тип заседания -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Место проведения"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   FontSize="13" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}" Height="36"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Тип заседания"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   FontSize="13" Margin="0,0,0,6"/>

                            <!-- ИСПРАВЛЕНО: TargetType="ComboBox", стиль через Setter -->
                            <ComboBox SelectedItem="{Binding CommissionType, UpdateSourceTrigger=PropertyChanged}"
                  Height="36">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}">
                                        <!-- ModernTextBox рассчитан на TextBox, но общие свойства (фон, рамка, отступы) подхватятся.
                         Если в ModernTextBox есть специфичные для TextBox свойства — они просто игнорируются для ComboBox. -->
                                    </Style>
                                </ComboBox.Style>

                                <ComboBoxItem Content="Плановое"/>
                                <ComboBoxItem Content="Внеплановое"/>
                                <ComboBoxItem Content="По жалобе пациента"/>
                                <ComboBoxItem Content="По требованию надзорного органа"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Состав комиссии (DataGrid) -->
                    <!-- Состав комиссии (редактируемый блок) -->
                    <Border Style="{StaticResource ModernBorder}" Margin="0,0,0,16" Padding="16">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                   Text="Состав комиссии"
                   Foreground="{StaticResource Brush.TextMain}"
                   FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

                            <!-- Панель управления (кнопки) -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="+ Добавить члена комиссии"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding AddMemberCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>

                                <Button Content="Удалить выбранного"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding RemoveMemberCommand}"
                    IsEnabled="{Binding SelectedMember, Converter={StaticResource HasValueConverter}}"
                    Padding="12,6" Margin="8,0,0,0"/>

                                <Separator Width="1" Background="{StaticResource Brush.Steel}" Margin="16,4"/>

                                <Button Content="Председатель"
                    Style="{StaticResource  AccentButton}"
                    Command="{Binding SetChairmanCommand}"
                    Padding="12,6" Margin="8,0,0,0"/>
                                <Button Content="Секретарь"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding SetSecretaryCommand}"
                    Padding="12,6" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Таблица членов комиссии -->
                            <DataGrid ItemsSource="{Binding Members}"
                  SelectedItem="{Binding SelectedMember}"
                  AutoGenerateColumns="False"
                  Style="{StaticResource ModernDataGrid}"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ф.И.О." Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="*" />
                                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="140" IsReadOnly="True" />

                                    <!-- Опционально: сделать Role редактируемым прямо в ячейке -->
                                    <!--<DataGridComboBoxColumn Header="Роль"
                                        SelectedItemBinding="{Binding Role}"
                                        Width="140">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.RolesList, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.RolesList, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>-->
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>


                    <!-- Повестка дня -->
                    <Border Style="{StaticResource ModernBorder}" Margin="0,0,0,16" Padding="10">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Повестка дня"
                                       Foreground="{StaticResource Brush.TextMain}"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding AgendaItems}"
                                      AutoGenerateColumns="False"
                                      Style="{StaticResource ModernDataGrid}"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№" Binding="{Binding OrderNumber}" Width="40"/>
                                    <DataGridTextColumn Header="Вопрос повестки" Binding="{Binding Topic}" Width="*"/>
                                    <DataGridTextColumn Header="Слушали" Binding="{Binding HeardSummary}" Width="*"/>
                                    <DataGridTextColumn Header="Рассмотрели" Binding="{Binding ReviewedDocuments}" Width="*"/>
                                    <DataGridTextColumn Header="Решение по вопросу" Binding="{Binding DecisionPerItem}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Голосование -->
                    <Border Style="{StaticResource ModernBorder}" Margin="0,0,0,16" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="«За»" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13"/>
                                <TextBox Text="{Binding VotesFor, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="36"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="«Против»" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13"/>
                                <TextBox Text="{Binding VotesAgainst, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="36"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="«Воздержался»" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13"/>
                                <TextBox Text="{Binding VotesAbstained, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="36"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Решение и особое мнение -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Решение комиссии" Foreground="{StaticResource Brush.TextMain}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DecisionText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="180" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1">
                            <StackPanel>
                                <TextBlock Text="Особое мнение" Foreground="{StaticResource Brush.TextMain}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding SpecialOpinionText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="180" Style="{StaticResource ModernTextBox}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,12,0" Width="Auto">
                                        <TextBlock Text="Автор" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding SpecialOpinionAuthorName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" Width="160" Height="36"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Должность" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding SpecialOpinionAuthorPosition, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" Width="200" Height="36"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки действий -->
        <DockPanel Grid.Row="2" Margin="0,20,0,0" LastChildFill="False">
            <Button Content="Сохранить" Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}" Padding="24,12" FontSize="14"/>
        </DockPanel>
    </Grid>
</Window>
