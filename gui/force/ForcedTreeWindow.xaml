<Window x:Class="Castor.gui.force.ForcedTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Castor.gui.common"
        Title="Учёт постановлений (принудительное лечение)"
        Width="1000" Height="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <converters:MonthToNameConverter x:Key="MonthToNameConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <!-- ИСПРАВЛЕНИЕ: ColumnDefinitions как коллекция ColumnDefinition -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === ЛЕВАЯ ЧАСТЬ: Список документов === -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.BackgroundAlt}"
                BorderBrush="{StaticResource Brush.Steel}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,8,0">
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding ForcedList}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     Margin="4"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6" Margin="2" CornerRadius="4" Background="Transparent">
                            <TextBlock Text="{Binding DisplayText}" Foreground="{StaticResource Brush.TextMain}" FontSize="13" Style="{StaticResource BaseText}"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- === ПРАВАЯ ЧАСТЬ: Форма === -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="{StaticResource Brush.Steel}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,0">
            <Grid  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Блок с данными пациента (акцентный фон) -->
                <Border Background="{StaticResource Brush.AccentLight}"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PatientInfo, Mode=OneWay, FallbackValue='Выберите запись для отображения данных пациента'}"
                                   Foreground="{StaticResource Brush.TextDark}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BaseText}"/>
                        <TextBlock Text="НОВАЯ" 
                                       Foreground="Green" FontWeight="SemiBold" Style="{StaticResource BaseText}" Visibility="{Binding IsNew}" HorizontalAlignment="Right" Margin="30,0,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" DataContext="{Binding SelectedItem}">

                    <TextBlock Text="Редактирование постановления"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,16"
                               Foreground="{StaticResource Brush.TextMain}"/>

                    <!-- Номер/идентификатор -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Номер/идентификатор"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <!-- Даты: начало и окончание -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Дата начала"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding Start, Converter={StaticResource DateOnlyConverter}, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernDatePicker}"
                                        Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Дата окончания"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding End,Converter={StaticResource DateOnlyConverter}, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernDatePicker}"
                                        Height="32"/>
                        </StackPanel>
                    </Grid>

                    <!-- Тип (100–199) -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Тип (100–199)"
                           Style="{StaticResource LabelText}"
                           Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource ModernComboBox}" SelectedValuePath="Tag"
                          Height="32">
                            <ComboBoxItem Tag="100">Амбулаторное</ComboBoxItem>
                            <ComboBoxItem Tag="101">Общий тип</ComboBoxItem>
                            <ComboBoxItem Tag="102">Специализированный тип</ComboBoxItem>
                            <ComboBoxItem Tag="103">СТИН</ComboBoxItem>
                            <ComboBoxItem Tag="104">Снято</ComboBoxItem>
                            <ComboBoxItem Tag="199">В переходе</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- Статья УК (Section) -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Статья УК (Section)"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Section, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="50"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Суд -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Суд"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Courtname, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <!-- Месяц (НОВОЕ ПОЛЕ) -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Месяц (отчётность)"
                               Style="{StaticResource LabelText}"
                               ToolTip="Номер месяца (1–12) для отчётности, если требуется"
                               Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Month, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MonthToNameConverter}}"
                                 Style="{StaticResource BaseText}"
                                 Height="32"
                                 Language="RU"
                                 TextAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0" Grid.Row="2" >

                    <Button Content="Месяцы" IsEnabled="{Binding CanEdit}"
                            Command="{Binding SetBaseCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="16,6"
                            Margin="0,0,8,0"/>
                    <Button Content="Добавить"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="16,6"
                            Margin="0,0,8,0"/>
                    <Button Content="Удалить"
                            Command="{Binding DeleteCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Style="{StaticResource HardButton}"
                            Padding="16,6"
                            Margin="0,0,8,0"/>
                    <Button Content="Сохранить"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="16,6"
                            Margin="0,0,8,0"/>

                    <!-- Нейтральная кнопка "Отмена" -->
                    <Button Content="Закрыть"
                                Click="Cancel_Click"
                                Style="{StaticResource HardButton}"
                                Padding="16,6"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
