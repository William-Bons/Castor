<Window x:Class="Castor.gui.force.ForcedTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт постановлений (принудительное лечение)"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дерево слева -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Steel}"
                BorderBrush="{StaticResource Brush.Charcoal}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8">
                    <Button Content="Обновить"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="10,4"/>
                </StackPanel>

                <TreeView Grid.Row="1"
                          ItemsSource="{Binding TreeItems}"
                          SelectedItemChanged="TreeView_OnSelectedItemChanged"
                          Margin="4">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource Brush.TextMain}"
                                       FontSize="13"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- Форма справа -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="{StaticResource Brush.Steel}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="8,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <TextBlock Text="Редактирование постановления"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,16"
                               Foreground="{StaticResource Brush.TextMain}"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Номер/идентификатор"
                                   Style="{StaticResource BaseText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Дата начала"
                                       Style="{StaticResource  BaseText}"
                                       Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding Start, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernDatePicker}"
                                        Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Дата окончания"
                                       Style="{StaticResource BaseText}"
                                       Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding End, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernDatePicker}"
                                        Height="32"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="PatientId"
                                       Style="{StaticResource  BaseText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="VisitId"
                                       Style="{StaticResource BaseText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding VisitId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Height="32"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Тип (100–199)"
                                   Style="{StaticResource  BaseText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource  ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Суд"
                                   Style="{StaticResource BaseText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CourtName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="MoveBookId"
                                   Style="{StaticResource BaseText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MoveBookId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="32"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="Сохранить"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource AccentButton}"
                                Padding="16,6"
                                Margin="0,0,8,0"/>
                        <Button Content="Создать новое"
                                Command="{Binding CreateCommand}"
                                Style="{StaticResource AccentButton}"
                                Padding="16,6"
                                Margin="0,0,8,0"/>  
                        <Button Content="Отмена"
                                Click="Cancel_Click"
                                Style="{StaticResource AccentButton}"
                                Padding="16,6"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
