<Page x:Class="Castor.gui.force.MonthsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Используем только ModernBorder из CASTOR -->
    <Border Style="{StaticResource ModernBorder}" Margin="8" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовки 1–6 -->
                <RowDefinition Height="*"/>
                <!-- Ячейки 1–6 -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовки 7–12 -->
                <RowDefinition Height="*"/>
                <!-- Ячейки 7–12 -->
            </Grid.RowDefinitions>

            <!-- Заголовки: 1–6 (только LabelText) -->
            <UniformGrid Grid.Row="0" Rows="1" Columns="6" Margin="0,0,0,8">
                <TextBlock Text="Январь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Февраль" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Март" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Апрель" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Май" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Июнь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </UniformGrid>

            <!-- Ячейки: 1–6 (списки пациентов) -->
            <UniformGrid Grid.Row="1" Rows="1" Columns="6">
                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth1}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Только BaseText из CASTOR -->
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth2}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth3}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth4}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth5}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth6}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </UniformGrid>

            <!-- Заголовки: 7–12 (только LabelText) -->
            <UniformGrid Grid.Row="2" Rows="1" Columns="6" Margin="0,0,0,8">
                <TextBlock Text="Июль" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Август" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Сентябрь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Октябрь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Ноябрь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Декабрь" Style="{StaticResource LabelText}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </UniformGrid>

            <!-- Ячейки: 7–12 (списки пациентов) -->
            <UniformGrid Grid.Row="3" Rows="1" Columns="6">
                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth7}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth8}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth9}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth10}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth11}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PatientsMonth12}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource BaseText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</Page>
