                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ListView ItemsSource="{Binding PatientsMonth8}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource MonthListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ListView ItemsSource="{Binding PatientsMonth9}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource MonthListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ListView ItemsSource="{Binding PatientsMonth10}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource MonthListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ListView ItemsSource="{Binding PatientsMonth11}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource MonthListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Style="{StaticResource ModernCell}" Margin="2">
                    <ListView ItemsSource="{Binding PatientsMonth12}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource MonthListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Movebook.Fio}" Style="{StaticResource BaseText}" Margin="0,2"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>

</Page>
