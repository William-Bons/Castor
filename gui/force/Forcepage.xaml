<Page x:Class="Castor.gui.force.Forcepage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Castor.gui.force"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Forcepage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/assets/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Добавить постановление суда" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/log_logout_door_1563.ico" />
                    <TextBlock Text="Поступление" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Фильтр"  Style="{DynamicResource Castor.Toolbarbutton}" Click="OpenHideContextMenu">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Скрыть сданные истории" IsCheckable="True"  x:Name="Hideclosed"/>
                        <MenuItem Header="Скрыть выписанные истории" IsCheckable="True"  x:Name="Hidedisordered"/>
                        <MenuItem Header="Фильтр дат" IsCheckable="True"  />
                    </ContextMenu>
                </Button.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/filter.png" />
                    <TextBlock Text="Фильтр" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Visibility="{Binding SaveButtonVisible}" Style="{DynamicResource Castor.Toolbarbutton}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/img/floppy_mount.png"/>
                    <TextBlock Text="Сохранить" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </ToolBar>


    </Grid>
</Page>
