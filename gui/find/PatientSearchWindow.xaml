<Window x:Class="Castor.gui.find.PatientSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск пациента и визитов"
        Height="750" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#FAFBFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <Border Grid.Row="0" Style="{StaticResource ModernBorder}" Margin="0,0,0,20" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- ФИО с поиском по Enter -->
                <TextBlock Text="ФИО:" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" FontSize="14" Margin="0,0,8,0"/>
                <TextBox Width="220"
                 Text="{Binding SearchFio, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,24,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- СНИЛС с поиском по Enter -->
                <TextBlock Text="СНИЛС:" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSecondary}" FontSize="14" Margin="0,0,8,0"/>
                <TextBox Width="170"
                 Text="{Binding SearchSnils, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,24,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Кнопка поиска (оставляем как есть — для клика мышкой) -->
                <Button Content="Найти" Command="{Binding SearchCommand}" Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </Border>

        <!-- Основная область: пациенты + сплиттер + визиты -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Пациенты: занимают всё свободное место слева -->
                <ColumnDefinition Width="*"/>
                <!-- Сплиттер: фиксированная узкая полоса -->
                <ColumnDefinition Width="4"/>
                <!-- Визиты: фиксированная ширина (можно тоже *) -->
                <ColumnDefinition Width="480"/>
            </Grid.ColumnDefinitions>

            <!-- Пациенты -->
            <Border Grid.Column="0" Style="{StaticResource ModernBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Пациенты" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextMain}" Padding="16,12"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Patients}"
                              SelectedItem="{Binding SelectedPatient}"
                              Style="{StaticResource ModernDataGrid}"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding lastname}" Width="160"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding firstname}" Width="130"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding secondname}" Width="170"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding birthdate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                            <DataGridTextColumn Header="СНИЛС" Binding="{Binding snils}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Перетаскиваемая граница -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D1D5DB"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          Margin="0"/>

            <!-- Визиты -->
            <Border Grid.Column="2" Style="{StaticResource ModernBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Визиты (последние)" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextMain}" Padding="16,12"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Visits}"
                              Style="{StaticResource ModernDataGrid}"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding dat, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                            <DataGridTextColumn Header="Тип визита" Binding="{Binding vistype}" Width="90"/>
                            <DataGridTextColumn Header="Отделение" Binding="{Binding depid}" Width="90"/>
                            <DataGridTextColumn Header="Врач" Binding="{Binding doctorid}" Width="90"/>
                            <DataGridTextColumn Header="Период" Binding="{Binding VPeriod}" Width="180"/>
                            <DataGridTextColumn Header="Дни в стационаре" Binding="{Binding DaysIn}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
