<DataGrid x:Class="Castor.gui.find.Findpatient_patients"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Castor.gui.find"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
    
    
             Grid.Row="0" Grid.Column="2" ItemsSource="{Binding Patients}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectedItem="{Binding Patient}" >
    
        <DataGrid.Columns>
            <DataGridTextColumn Header="" Binding="{Binding fullname}"/>
            <DataGridTextColumn Header="" Binding="{Binding age}"/>
            <DataGridTextColumn Header="" Binding="{Binding birthdate}"/>
            <DataGridTextColumn Header="" Binding="{Binding city}"/>
        </DataGrid.Columns>
    
</DataGrid>
