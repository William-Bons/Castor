<Window x:Class="Castor.gui.commities.CommityForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Castor.gui.commities"
        Title="Заполнение данных ВК" Height="480" Width="420"
        WindowStartupLocation="CenterScreen" Background="#F4F6F9">
    
    <Window.Resources>
        <!-- Стиль для подписей -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- Шаблон отображения ошибки (Красная рамка и подсказка) -->
        <ControlTemplate x:Key="ValidationTemplate">
            <DockPanel>
                <Border BorderBrush="#E74C3C" BorderThickness="1.5" CornerRadius="4">
                    <AdornedElementPlaceholder x:Name="ControlSpace"/>
                </Border>
                <TextBlock Text="{Binding [0].ErrorContent}" Foreground="#E74C3C" 
                           FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </DockPanel>
        </ControlTemplate>

        <!-- Общий стиль для TextBox, ComboBox и DatePicker -->
        <Style TargetType="Control" x:Key="InputControlStyle">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationTemplate}"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource InputControlStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource InputControlStyle}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource InputControlStyle}"/>

        <!-- Стиль для интерактивной кнопки -->
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2980B9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Foreground" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Padding="25" Background="White" CornerRadius="8" Margin="15" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Заголовок -->
                <RowDefinition Height="Auto"/> <!-- Movebook -->
                <RowDefinition Height="Auto"/> <!-- Visit -->
                <RowDefinition Height="Auto"/> <!-- Patient -->
                <RowDefinition Height="Auto"/> <!-- Type -->
                <RowDefinition Height="Auto"/> <!-- Start -->
                <RowDefinition Height="Auto"/> <!-- Closed -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/> <!-- Кнопка -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                       Text="Параметры Врачебной Комиссии" FontSize="16" FontWeight="Bold" 
                       Foreground="#2C3E50" Margin="0,0,0,15"/>

            <!-- Обратите внимание на ValidatesOnNotifyDataErrors=True -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="ID Книги движений:" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MovebookIdInput, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="ID Визита (Medis):" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VisitIdInput, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="ID Пациента:" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PatientIdInput, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Вид ВК:" Style="{StaticResource LabelStyle}"/>
            <ComboBox Grid.Row="4" Grid.Column="1" 
                      SelectedValue="{Binding SelectedType, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                      SelectedValuePath="Key" DisplayMemberPath="Value"
                      ItemsSource="{Binding TypeOptions}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата начала:" Style="{StaticResource LabelStyle}"/>
            <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата закрытия:" Style="{StaticResource LabelStyle}"/>
            <DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding ClosedDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

            <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" 
                    Content="Сохранить данные" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"/>
        </Grid>
    </Border>
</Window>
