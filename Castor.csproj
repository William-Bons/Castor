<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="gui\pages\MakeNewPlanning.xaml.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="img\acroread.png" />
    <None Remove="img\add-icon.png" />
    <None Remove="img\ariadna-logo.png" />
    <None Remove="img\edit.png" />
    <None Remove="img\filter.png" />
    <None Remove="img\floppy_mount.png" />
    <None Remove="img\kurwa.jpg" />
    <None Remove="img\registrator.png" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="assets\Style.xaml" />
    <Page Remove="gui\pages\MakeNewPlanning.xaml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="assets\Style.xaml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FastReport.OpenSource" Version="2025.2.11" />
    <PackageReference Include="HtmlAgilityPack" Version="1.12.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.7">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.7" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="9.0.7" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />
    <PackageReference Include="Select.HtmlToPdf.NetCore" Version="25.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="img\acroread.png" />
    <Resource Include="img\add-icon.png" />
    <Resource Include="img\ariadna-logo.png" />
    <Resource Include="img\edit.png" />
    <Resource Include="img\filter.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="img\floppy_mount.png" />
    <Resource Include="img\kurwa.jpg">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="img\registrator.png" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="gui\pages\ForceControl.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="Properties\ResourceRu.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ResourceRu.resx</DependentUpon>
    </Compile>
    <Compile Update="Properties\Settings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\ResourceRu.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ResourceRu.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="assets\BlockTrTd.css">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="assets\MainMenu.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="assets\MonthReport.css">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <None Update="sqlite\movebook_create.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
