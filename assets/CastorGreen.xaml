<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- ========================================== -->
    <!-- CastorGreen: полная копия CastorSoft с зелёной палитрой -->
    <!-- Все ключи сохранены, изменены только основные цветовые значения -->
    <!-- ========================================== -->

    <!-- ПАЛИТРА (Светлая, мягкая, зелёная)     -->

    <Color x:Key="Color.Steel">#F5F7FA</Color>
    <Color x:Key="Color.Graphite">#5A626E</Color>
    <Color x:Key="Color.Charcoal">#4A525D</Color>
    <Color x:Key="Color.Accent">#2E8B57</Color>

    <SolidColorBrush x:Key="Brush.Steel" Color="{StaticResource Color.Steel}"/>
    <SolidColorBrush x:Key="Brush.Graphite" Color="{StaticResource Color.Graphite}"/>
    <SolidColorBrush x:Key="Brush.Charcoal" Color="{StaticResource Color.Charcoal}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.BackgroundAlt" Color="#F4FAF6"/>
    <SolidColorBrush x:Key="Brush.AccentLight" Color="#E8F6EA"/>
    <!-- чуть светлее акцента -->
    <SolidColorBrush x:Key="Brush.TextDark" Color="#2D333B"/>
    <SolidColorBrush x:Key="Brush.TextMain" Color="#2D333B"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#8C949D"/>

    <!-- Фон поверхности (светлый, нейтральный) -->
    <Color x:Key="Color.Surface">#F9F9F9</Color>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>

    <!-- Цвет границы (серый, спокойный) -->
    <Color x:Key="Color.Border">#D1D1D1</Color>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>

    <!-- Основной текст (тёмный, высокая контрастность) -->
    <Color x:Key="Color.TextPrimary">#212121</Color>
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>

    <!-- Цвет текста при наведении/выделении -->
    <Color x:Key="Color.TextAccent">#124F2E</Color>
    <SolidColorBrush x:Key="Brush.TextAccent" Color="{StaticResource Color.TextAccent}"/>

    <System:Double x:Key="GlobalControlMinHeight">32</System:Double>

    <!-- Рамка всей панели: тонкая, нейтральная, скруглённая -->
    <Style x:Key="ModernBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>

    <!-- Ячейка месяца: чуть светлее, чем панель, с отступом -->
    <Style x:Key="ModernCell" TargetType="Border">
        <Setter Property="BorderBrush" Value="#EEEEEE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#F9F9F9"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    

  


</ResourceDictionary>
